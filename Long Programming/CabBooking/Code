import java.util.Scanner;

// Customer class
class Customer {
    String name;
    String pickup;
    String drop;

    void getCustomerDetails(Scanner sc) {
        System.out.print("Enter Customer Name: ");
        name = sc.nextLine();

        System.out.print("Enter Pickup Location: ");
        pickup = sc.nextLine();

        System.out.print("Enter Drop Location: ");
        drop = sc.nextLine();
    }
}

// Cab class
class Cab {
    String cabType;
    int ratePerKm;

    void selectCab(Scanner sc) {
        System.out.println("\nSelect Cab Type:");
        System.out.println("1. Mini (₹10/km)");
        System.out.println("2. Sedan (₹15/km)");
        System.out.println("3. SUV (₹20/km)");

        int choice = sc.nextInt();

        switch (choice) {
            case 1:
                cabType = "Mini";
                ratePerKm = 10;
                break;
            case 2:
                cabType = "Sedan";
                ratePerKm = 15;
                break;
            case 3:
                cabType = "SUV";
                ratePerKm = 20;
                break;
            default:
                System.out.println("Invalid choice, defaulting to Mini");
                cabType = "Mini";
                ratePerKm = 10;
        }
    }
}

// Booking class
class Booking {
    int distance;
    int fare;

    void calculateFare(int rate) {
        fare = distance * rate;
    }

    void getDistance(Scanner sc) {
        System.out.print("\nEnter Distance (in km): ");
        distance = sc.nextInt();
    }

    void display(Customer c, Cab cab) {
        System.out.println("\n--- Booking Details ---");
        System.out.println("Customer Name: " + c.name);
        System.out.println("Pickup: " + c.pickup);
        System.out.println("Drop: " + c.drop);
        System.out.println("Cab Type: " + cab.cabType);
        System.out.println("Distance: " + distance + " km");
        System.out.println("Total Fare: ₹" + fare);
    }
}

// Main class
public class CabBookingSystem {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        Customer c = new Customer();
        Cab cab = new Cab();
        Booking b = new Booking();

        System.out.println("===== CAB BOOKING SYSTEM =====");

        c.getCustomerDetails(sc);
        cab.selectCab(sc);
        b.getDistance(sc);

        b.calculateFare(cab.ratePerKm);
        b.display(c, cab);

        sc.close();
    }
}
