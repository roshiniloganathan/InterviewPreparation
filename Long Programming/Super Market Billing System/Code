import java.util.Scanner;

// Product class
class Product {
    String name;
    int price;
    int quantity;

    void getProduct(Scanner sc) {
        sc.nextLine(); // clear buffer

        System.out.print("Enter Product Name: ");
        name = sc.nextLine();

        System.out.print("Enter Price: ");
        price = sc.nextInt();

        System.out.print("Enter Quantity: ");
        quantity = sc.nextInt();
    }

    int calculateTotal() {
        return price * quantity;
    }
}

// Bill class
class Bill {
    int totalAmount = 0;

    void addAmount(int amount) {
        totalAmount += amount;
    }

    void displayBill() {
        System.out.println("\n===== FINAL BILL =====");
        System.out.println("Total Amount: ₹" + totalAmount);
    }
}

// Main class
public class SuperMarketBilling {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Bill bill = new Bill();

        System.out.println("===== SUPERMARKET BILLING SYSTEM =====");

        System.out.print("Enter number of products: ");
        int n = sc.nextInt();

        Product[] products = new Product[n];

        for (int i = 0; i < n; i++) {
            products[i] = new Product();
            System.out.println("\nProduct " + (i + 1) + ":");
            products[i].getProduct(sc);

            int total = products[i].calculateTotal();
            bill.addAmount(total);
        }

        // Display details
        System.out.println("\n----- Product Details -----");
        for (int i = 0; i < n; i++) {
            System.out.println("Product: " + products[i].name +
                               " | Price: ₹" + products[i].price +
                               " | Qty: " + products[i].quantity +
                               " | Total: ₹" + products[i].calculateTotal());
        }

        bill.displayBill();

        sc.close();
    }
}
